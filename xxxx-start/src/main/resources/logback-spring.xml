<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="APP_NAME" value="MyEventApplication"/>
    <property name="LOG_PATH" value="${user.home}/${APP_NAME}/logs"/>

    <!-- Logstash: chỉ bật khi ELK đang chạy (LOGSTASH_ENABLED=true) -->
    <appender name="LOG_STASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>localhost:5044</destination>
        <!-- Giới hạn buffer: tránh heap tràn khi Logstash không chạy -->
        <queueSize>512</queueSize>
        <keepAliveDuration>5 minutes</keepAliveDuration>
        <reconnectionDelay>10 seconds</reconnectionDelay>
        <encoder charset="UTF-8" class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp><timeZone>UTC</timeZone></timestamp>
                <pattern>
                    <pattern>
                        {
                        "mv_date": "%d{yyyy-MM-dd HH:mm:ss:SSS}",
                        "mv_ip": "111.222.333.444",
                        "mv_thread": "%thread",
                        "mv_traceId": "%X{traceId}",
                        "mv_level": "%level",
                        "mv_logger": "%logger{40}",
                        "mv_message": "%msg%n"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!-- Async wrapper: không block thread khi queue đầy, discard thay vì OOM -->
    <appender name="ASYNC_STASH" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="LOG_STASH"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
    </appender>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>utf8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss:SSS}|%thread|%X{traceId}|%level|%logger{36}|%msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="ASYNC_STASH"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>