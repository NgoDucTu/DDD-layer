    {
      "id": 42, "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 }, "max": 1 } },
