      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
        "expr": "redis_memory_used_bytes / 1024 / 1024",
        "legendFormat": "used MB"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 }, "id": 104, "title": "JVM and System", "type": "row" },

    {
      "id": 40, "type": "timeseries",
      "title": "JVM Heap Memory",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
