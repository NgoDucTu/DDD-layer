    {
      "id": 41, "type": "timeseries",
      "title": "JVM Threads",
      "description": "Virtual threads enabled → count co the len cao nhung binh thuong.",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
