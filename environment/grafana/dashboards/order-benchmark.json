    {
      "id": 201, "type": "timeseries",
      "title": "RPS — CAS vs MQ (cùng chart)",
      "description": "MQ cao hơn vì không bị block bởi InnoDB lock. CAS bị serialized tại DB.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CAS (sync)" },  "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MQ (async)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
          "expr": "sum(irate(http_server_requests_seconds_count{application=\"xxxx.com\", uri=\"/order/cas\"}[1m]))",
          "legendFormat": "CAS (sync)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "ffl76qyrsqzuoe" },
          "expr": "sum(irate(http_server_requests_seconds_count{application=\"xxxx.com\", uri=\"/order/mq\"}[1m]))",
          "legendFormat": "MQ (async)"
        }
      ]
    },

